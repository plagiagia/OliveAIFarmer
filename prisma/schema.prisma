// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User management
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique // Clerk user ID
  email     String   @unique
  firstName String
  lastName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // User's farms
  farms Farm[]

  @@map("users")
}

// Farm/Olive Grove
model Farm {
  id          String   @id @default(cuid())
  name        String   // e.g., "Ελαιώνας Μεσσηνίας"
  location    String   // e.g., "Καλαμάτα, Μεσσηνία"
  coordinates String?  // GPS coordinates (optional)
  totalArea   Float?   // Total farm area in stremmata (στρέμματα)
  treeCount   Int?     // Number of olive trees in the farm
  oliveVariety String? // Primary olive variety (e.g., "Κορωνέικη", "Καλαμών")
  treeAge     Int?     // Average age of trees in years (optional)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Owner
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Activities and harvests
  activities Activity[]
  harvests   Harvest[]

  // Smart recommendations
  recommendations SmartRecommendation[]

  // Weather history
  weatherRecords WeatherRecord[]

  @@map("farms")
}



// Farm activities (watering, pruning, fertilizing, etc.)
model Activity {
  id           String       @id @default(cuid())
  type         ActivityType
  title        String       // e.g., "Πότισμα Βόρειου Τμήματος"
  description  String?
  date         DateTime
  duration     Int?         // Duration in minutes
  cost         Float?       // Cost in euros
  weather      String?      // Weather conditions
  notes        String?
  completed    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Parent farm
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@map("activities")
}


// Harvest records
model Harvest {
  id               String        @id @default(cuid())
  year             Int           // Harvest year
  startDate        DateTime
  endDate          DateTime?
  collectionDate   DateTime?     // Date of this specific collection event
  totalYield       Float?        // Total yield in kg
  totalYieldTons   Float?        // Total yield in tons (calculated from totalYield)

  // Enhanced pricing information
  pricePerKg       Float?        // Price per kilogram
  pricePerTon      Float?        // Price per ton
  priceUnit        PriceUnit     @default(PER_KG)
  totalValue       Float?        // Total harvest value (calculated)
  currency         String        @default("EUR")

  // Enhanced production metrics
  yieldPerTree     Float?        // Average yield per tree (calculated)
  yieldPerStremma  Float?        // Yield per stremma (calculated)

  notes            String?
  completed        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Parent farm
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@map("harvests")
}


// Enums
enum ActivityType {
  WATERING      // Πότισμα
  PRUNING       // Κλάδεμα
  FERTILIZING   // Λίπανση
  PEST_CONTROL  // Έλεγχος Παρασίτων
  SOIL_WORK     // Εργασίες Εδάφους
  HARVESTING    // Συγκομιδή
  MAINTENANCE   // Συντήρηση
  INSPECTION    // Επιθεώρηση
  OTHER         // Άλλο
}

enum PriceUnit {
  PER_KG        // Ανά κιλό
  PER_TON       // Ανά τόνο
  PER_LITER     // Ανά λίτρο (για λάδι)
}

// Smart recommendations based on context
model SmartRecommendation {
  id              String             @id @default(cuid())
  type            RecommendationType
  title           String
  message         String
  actionRequired  Boolean @default(false)
  urgency         Priority

  // Source of the recommendation
  source          InsightSource @default(RULE_BASED)
  reasoning       String?       // AI reasoning for the recommendation

  // Trigger conditions
  triggerConditions Json?            // Complex conditions (optional for AI insights)
  validFrom       DateTime @default(now())
  validUntil      DateTime?

  // Context
  farmId          String?
  weatherBased    Boolean @default(false)
  seasonBased     Boolean @default(false)

  // Tracking
  isRead          Boolean @default(false)
  isActioned      Boolean @default(false)
  readAt          DateTime?
  actionedAt      DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  farm            Farm? @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@map("smart_recommendations")
}

// ===== ENUMS FOR RECOMMENDATIONS =====

enum Priority {
  LOW      // Χαμηλή
  MEDIUM   // Μέτρια
  HIGH     // Υψηλή
  CRITICAL // Κρίσιμη
}

enum RecommendationType {
  TASK_REMINDER    // Υπενθύμιση εργασίας
  WEATHER_ALERT    // Καιρική προειδοποίηση
  SEASONAL_TIP     // Εποχιακή συμβουλή
  CARE_SUGGESTION  // Πρόταση φροντίδας
  RISK_WARNING     // Προειδοποίηση κινδύνου
  OPTIMIZATION     // Βελτίωση
}

enum InsightSource {
  RULE_BASED       // Από κανόνες συστήματος
  AI_GENERATED     // Από AI Γεωπόνο
  WEATHER_ALERT    // Από καιρικές συνθήκες
  USER_CREATED     // Από τον χρήστη
}

// ===== WEATHER HISTORY STORAGE =====

// Daily weather records for each farm
model WeatherRecord {
  id          String   @id @default(cuid())

  // Parent farm
  farmId      String
  farm        Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  // Timestamp - the specific date this record is for
  date        DateTime // Normalized to midnight UTC for the day
  recordedAt  DateTime @default(now()) // When this record was created/updated

  // Temperature (Celsius)
  tempHigh    Float    // Highest temperature of the day
  tempLow     Float    // Lowest temperature of the day
  tempAvg     Float    // Average temperature

  // Humidity (percentage)
  humidity    Int      // Average humidity

  // Precipitation (mm)
  rainfall    Float    @default(0) // Total rainfall in mm

  // Wind (m/s)
  windSpeed   Float    // Average wind speed
  windGust    Float?   // Max wind gust (if available)
  windDirection Int?   // Wind direction in degrees (0-360, where 0=North)

  // Atmospheric conditions
  pressure    Int?     // Atmospheric pressure in hPa
  clouds      Int?     // Cloud coverage percentage (0-100)
  uvIndex     Float?   // UV index (requires One Call API, may not always be available)

  // Weather condition
  condition   String   // Main condition (sunny, cloudy, rainy, etc.)
  icon        String?  // Weather icon code from API

  // Data source tracking
  source      WeatherDataSource @default(API_CURRENT)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // One record per farm per day
  @@unique([farmId, date])
  @@index([farmId])
  @@index([date])
  @@index([farmId, date])
  @@map("weather_records")
}

enum WeatherDataSource {
  API_CURRENT   // From current weather API call
  API_FORECAST  // From forecast API
  CRON_DAILY    // From daily cron job
  MANUAL        // Manually entered
}
