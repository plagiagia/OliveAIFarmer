# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@host:5432/olivelog?sslmode=require

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Mapbox (for maps and location features)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.eyJ1...

# Vercel Blob Storage (for photo uploads)
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# OpenWeatherMap API (for weather intelligence)
# Get your free API key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_api_key_here

# Vercel Cron Security
# Generate a random secret for cron job authentication
# You can generate one with: openssl rand -base64 32
CRON_SECRET=your_cron_secret_here

# OpenAI API (for AI Geoponos insights)
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
