{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "app/api/**/*.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/weather",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/satellite",
      "schedule": "0 7 * * 0"
    }
  ]
}
