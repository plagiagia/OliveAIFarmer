{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["fra1"],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "src/app/api/**/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/insights/**/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/**/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/weather",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/satellite",
      "schedule": "0 7 * * 0"
    }
  ]
}
